<?xml version="1.0" encoding="utf-8"?>
<!--
  Branded launch drawable.
  Uses a layer-list so the OS shows it instantly as the window background
  before the React Native bundle is ready (no blank screen).
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android"
    android:opacity="opaque">

    <!-- Background: brand cream -->
    <item>
        <color android:color="@color/splashBg" />
    </item>

    <!-- Centred terracotta circle (gravity centres the shape inside the layer) -->
    <item
        android:gravity="center"
        android:bottom="110dp"
        android:top="110dp"
        android:left="137dp"
        android:right="137dp">
        <shape android:shape="oval">
            <solid android:color="@color/splashPrimary" />
        </shape>
    </item>

</layer-list>
